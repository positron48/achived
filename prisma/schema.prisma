generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Goal {
  id            String      @id @default(cuid())
  boardId       String?
  board         Board?      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title         String
  description   String      @default("")
  status        GoalStatus  @default(TODO)
  priority      Int         @default(3)
  type          GoalType    @default(TASK)
  x             Float       @default(0)
  y             Float       @default(0)
  /// Не раньше этого календарного дня можно брать в работу (локальная дата клиента при выборе).
  startsOn      DateTime?   @db.Date
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  changeLog     GoalChange[]
  outgoingEdges GoalEdge[]  @relation("SourceGoal")
  incomingEdges GoalEdge[]  @relation("TargetGoal")

  @@index([boardId])
}

model GoalChange {
  id          String   @id @default(cuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  boardId      String
  userId       String
  userEmail    String?
  changedField String
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())

  @@index([goalId, createdAt])
  @@index([boardId, createdAt])
}

model GoalEdge {
  id        String   @id @default(cuid())
  boardId   String?
  board     Board?   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  sourceId  String
  targetId  String
  source    Goal     @relation("SourceGoal", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Goal     @relation("TargetGoal", fields: [targetId], references: [id], onDelete: Cascade)
  type      EdgeType @default(REQUIRES)
  /// Точки излома в координатах React Flow (абсолютные), упорядочены от source к target.
  waypoints Json?
  createdAt DateTime @default(now())

  @@unique([boardId, sourceId, targetId, type])
  @@index([boardId])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  avatarUrl    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  authAccounts AuthAccount[]
  ownedBoards  Board[]        @relation("BoardOwner")
  boardMembers BoardMember[]
  settings     UserSettings?
}

/// Персональные настройки UI (привязка к сетке, панели графа).
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  graphGridSnapEnabled  Boolean @default(false)
  graphLeftSidebarOpen  Boolean @default(true)
  graphRightSidebarOpen Boolean @default(true)

  updatedAt DateTime @updatedAt
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Board {
  id                String        @id @default(cuid())
  ownerId           String?
  owner             User?         @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  title             String
  isPublicReadOnly  Boolean       @default(false)
  publicShareToken  String?       @unique
  isLegacyUnclaimed Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  goals             Goal[]
  edges             GoalEdge[]
  members           BoardMember[]

  @@index([ownerId])
}

model BoardMember {
  id        String     @id @default(cuid())
  boardId   String
  board     Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(VIEWER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([boardId, userId])
  @@index([userId])
}

enum GoalStatus {
  TODO
  ACTIVE
  DONE
  BLOCKED
  DROPPED
}

enum GoalType {
  EPIC
  MILESTONE
  TASK
  HABIT
}

enum EdgeType {
  REQUIRES
  RELATED
}

enum MemberRole {
  VIEWER
  EDITOR
}
